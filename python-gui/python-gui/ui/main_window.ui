    <item>
<widget class="QLabel" name="subtitle_label">
    <property name="text">
        <string>
            &lt;html&gt;&lt;head/&gt;&lt;body&gt;
            &lt;p style="font-size: 16px; color: #495057;"&gt;
            JoularJX is a Java-based agent for power monitoring at the source code level with support for modern Java versions and multi-OS to monitor power consumption of hardware and software.
            &lt;/p&gt;
            &lt;p style="font-size: 13px; color: #0d6efd;"&gt;
            &lt;a href="https://github.com/joular/joularjx" style="text-decoration: none;"&gt;GitHub Repository&lt;/a&gt;&#160;&#160;&#160;&#160;
            &lt;a href="https://joular.github.io/joularjx/overview.html" style="text-decoration: none;"&gt;Documentation&lt;/a&gt;&#160;&#160;&#160;&#160;
            &lt;a href="https://www.noureddine.org/research/joular/joularjx" style="text-decoration: none;"&gt;Official Website&lt;/a&gt;
            &lt;/p&gt;
            &lt;/body&gt;&lt;/html&gt;
        </string>
    </property>
    <property name="alignment">
        <set>Qt::AlignLeft</set>
    </property>
    <property name="wordWrap">
        <bool>true</bool>
    </property>
    <property name="openExternalLinks">
        <bool>true</bool>
    </property>
    <property name="styleSheet">
        <string>
            margin: 0px;
        </string>
    </property>
</widget>
